{
  "name": "ai-study-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently --kill-others --prefix \"[{name}]\" --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"node server/index.js\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "chart.js": "^4.5.1",
    "firebase": "^12.11.0",
    "html2pdf.js": "^0.14.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "pptx-parser": "^1.1.7-beta.9",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tesseract.js": "^7.0.0",
    "youtube-transcript": "^1.3.0"
  }
}
